#include <SFSE/SFSE.h>

SFSE_PLUGIN_VERSION = []() noexcept {
    SFSE::PluginVersionData v{};
    v.PluginVersion({ ${COMMONLIB_PLUGIN_VERSION_MAJOR}, ${COMMONLIB_PLUGIN_VERSION_MINOR}, ${COMMONLIB_PLUGIN_VERSION_PATCH} });
    v.PluginName("${COMMONLIB_PLUGIN_NAME}");
    v.AuthorName("${COMMONLIB_PLUGIN_AUTHOR}");
    v.UsesSigScanning(${COMMONLIBSF_OPTION_SIG_SCANNING});
    v.UsesAddressLibrary(${COMMONLIBSF_OPTION_ADDRESS_LIBRARY});
    v.HasNoStructUse(${COMMONLIBSF_OPTION_NO_STRUCT_USE});
    v.IsLayoutDependent(${COMMONLIBSF_OPTION_LAYOUT_DEPENDENT});
    v.CompatibleVersions({ SFSE::RUNTIME_LATEST });
    return v;
}();
